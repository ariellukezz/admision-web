{
    "openapi": "3.0.0",
    "info": {
        "title": "API Admisión UNAP",
        "description": "API del sistema de admisión de la Universidad Nacional del Altiplano de Puno.\n\n## Módulos\n\n- **Revisor**: Endpoints para la revisión de documentos, dashboard, notificaciones y gestión de postulantes.\n- **Health Check**: Estado del sistema.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost",
            "description": "Servidor local (Laragon)"
        }
    ],
    "paths": {
        "/revisor/dashboard/resumen": {
            "get": {
                "tags": [
                    "Revisor - Dashboard"
                ],
                "summary": "Resumen general del proceso",
                "description": "KPIs: inscritos, preinscritos, biometricos, documentos y comprobantes pendientes/verificados",
                "operationId": "9261535ccde59529e24f91b98ae22d8a",
                "responses": {
                    "200": {
                        "description": "Resumen del dashboard",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "OK"
                                        },
                                        "data": {
                                            "properties": {
                                                "inscritos": {
                                                    "type": "integer",
                                                    "example": 150
                                                },
                                                "inscritos_hoy": {
                                                    "type": "integer",
                                                    "example": 12
                                                },
                                                "preinscritos": {
                                                    "type": "integer",
                                                    "example": 300
                                                },
                                                "documentos_pendientes": {
                                                    "type": "integer",
                                                    "example": 45
                                                },
                                                "comprobantes_pendientes": {
                                                    "type": "integer",
                                                    "example": 30
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/revisor/dashboard/inscripciones-por-programa": {
            "get": {
                "tags": [
                    "Revisor - Dashboard"
                ],
                "summary": "Inscripciones por programa (top 12)",
                "operationId": "2c694b47616741afbce51b80f5709070",
                "responses": {
                    "200": {
                        "description": "Lista de programas con cantidad de inscritos"
                    }
                }
            }
        },
        "/revisor/dashboard/biometrico-resumen": {
            "get": {
                "tags": [
                    "Revisor - Dashboard"
                ],
                "summary": "Resumen de control biométrico",
                "operationId": "f23ab88d44283ede549d14ee0dc79946",
                "responses": {
                    "200": {
                        "description": "Total de inscritos con/sin biométrico"
                    }
                }
            }
        },
        "/revisor/iniciar-revision/{dni}": {
            "post": {
                "tags": [
                    "Revisor - Documentos"
                ],
                "summary": "Iniciar revisión de documentos",
                "operationId": "07c978f84339d3f65456ee777d7de656",
                "parameters": [
                    {
                        "name": "dni",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "solicitud_id": {
                                        "type": "integer",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Revisión iniciada"
                    },
                    "404": {
                        "description": "Postulante no encontrado"
                    }
                }
            }
        },
        "/revisor/finalizar-revision/{dni}": {
            "post": {
                "tags": [
                    "Revisor - Documentos"
                ],
                "summary": "Finalizar revisión de documentos",
                "description": "Si todos los documentos son válidos: marca como completada y genera citación. Si hay pendientes: marca como pendiente y notifica al postulante.",
                "operationId": "bc16395f7a5856eff3a634bc7fc6c5bb",
                "parameters": [
                    {
                        "name": "dni",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "fecha",
                                    "hora_inicio",
                                    "hora_fin",
                                    "lugar"
                                ],
                                "properties": {
                                    "solicitud_id": {
                                        "type": "integer",
                                        "nullable": true
                                    },
                                    "fecha": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-07-15"
                                    },
                                    "hora_inicio": {
                                        "type": "string",
                                        "example": "08:00"
                                    },
                                    "hora_fin": {
                                        "type": "string",
                                        "example": "10:00"
                                    },
                                    "lugar": {
                                        "type": "string",
                                        "example": "Sala de Revisión - Pabellón A"
                                    },
                                    "instrucciones": {
                                        "type": "string",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Revisión finalizada"
                    }
                }
            }
        },
        "/revisor/revision-rapida/{dni}": {
            "post": {
                "tags": [
                    "Revisor - Documentos"
                ],
                "summary": "Revisión rápida: marcar todos los documentos como válidos",
                "operationId": "43a3b93d299ba9fc6534d947c1c92a9f",
                "parameters": [
                    {
                        "name": "dni",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Documentos marcados como válidos"
                    }
                }
            }
        },
        "/revisor/cambiar-estado-documento": {
            "post": {
                "tags": [
                    "Revisor - Documentos"
                ],
                "summary": "Cambiar estado de un documento individual",
                "operationId": "311721b0f12eea3a261223a07745157d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id_documento",
                                    "accion"
                                ],
                                "properties": {
                                    "id_documento": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "accion": {
                                        "type": "string",
                                        "enum": [
                                            "apto_revision",
                                            "valido",
                                            "desmarcar"
                                        ]
                                    },
                                    "fecha_caducidad": {
                                        "type": "string",
                                        "format": "date",
                                        "nullable": true
                                    },
                                    "observacion": {
                                        "type": "string",
                                        "nullable": true,
                                        "maxLength": 1000
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Estado del documento actualizado"
                    }
                }
            }
        },
        "/revisor/documentos-requisitos/{dni}": {
            "get": {
                "tags": [
                    "Revisor - Documentos"
                ],
                "summary": "Documentos del postulante agrupados por requisitos",
                "operationId": "478fe57e00c351876d1b8042e211492f",
                "parameters": [
                    {
                        "name": "dni",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "solicitud",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de requisitos con documentos"
                    }
                }
            }
        },
        "/revisor/notificaciones": {
            "get": {
                "tags": [
                    "Revisor - Notificaciones"
                ],
                "summary": "Listar notificaciones del revisor",
                "operationId": "e59dba0121a3fe244ac48f268c6759d7",
                "parameters": [
                    {
                        "name": "limit",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 20
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de notificaciones"
                    }
                }
            }
        },
        "/revisor/notificaciones/{id}/leer": {
            "post": {
                "tags": [
                    "Revisor - Notificaciones"
                ],
                "summary": "Marcar notificación como leída",
                "operationId": "97911e98e37630ad8b349e60bbdf2974",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Notificación marcada como leída"
                    }
                }
            }
        },
        "/revisor/mi-actividad/resumen": {
            "get": {
                "tags": [
                    "Revisor - Mi Actividad"
                ],
                "summary": "KPIs personales del revisor",
                "operationId": "620bad98a21be6ebb35f870dc3668a7d",
                "responses": {
                    "200": {
                        "description": "Resumen de actividad personal"
                    }
                }
            }
        },
        "/revisor/mi-actividad/timeline": {
            "get": {
                "tags": [
                    "Revisor - Mi Actividad"
                ],
                "summary": "Timeline de actividad (últimos 30 días)",
                "operationId": "256c981f6af4dc62517bc86705748bc4",
                "responses": {
                    "200": {
                        "description": "Serie temporal de actividad diaria"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Token Sanctum (Bearer token)",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Revisor - Dashboard",
            "description": "Revisor - Dashboard"
        },
        {
            "name": "Revisor - Documentos",
            "description": "Revisor - Documentos"
        },
        {
            "name": "Revisor - Notificaciones",
            "description": "Revisor - Notificaciones"
        },
        {
            "name": "Revisor - Mi Actividad",
            "description": "Revisor - Mi Actividad"
        }
    ]
}